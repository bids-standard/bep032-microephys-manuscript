	keywords = {decision-making, electrophsyiology, neuropixels, open science, reproducibility, vision},
	pages = {RP100840},
	file = {Full Text PDF:/home/gupta/Zotero/storage/D4FDTZZB/International Brain Laboratory et al. - 2025 - Reproducibility of in vivo electrophysiological measurements in mice.pdf:application/pdf},
