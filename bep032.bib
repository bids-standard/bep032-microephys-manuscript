	note = {Publisher: Nature Publishing Group},
	keywords = {Research data, Data publication and archiving},
	pages = {160044},
	file = {Full Text PDF:/home/gupta/Zotero/storage/L5UE6YF4/Gorgolewski et al. - 2016 - The brain imaging data structure, a format for organizing and describing outputs of neuroimaging exp.pdf:application/pdf},
}

