% manuscript-style.sty — Nature-like formatting for generic manuscript
% Based on the visual style of Nature Scientific Reports
% Clean reimplementation using standard article class

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{manuscript-style}[2026/03/16 Nature-like manuscript formatting]

%% ---- Fonts ----
\RequirePackage{times}        % Times Roman body text
\RequirePackage{mathptmx}     % Times Roman math
\RequirePackage{microtype}    % Microtypographic refinements

%% ---- Page geometry ----
\RequirePackage[
    a4paper,
    left=2cm,
    right=2cm,
    top=2.25cm,
    bottom=2.25cm,
    headheight=12pt,
]{geometry}

%% ---- Line spacing ----
\RequirePackage[onehalfspacing]{setspace}

%% ---- Author block ----
\RequirePackage{authblk}
\setlength{\affilsep}{1em}
\renewcommand\Authfont{\fontsize{12}{14}\usefont{OT1}{phv}{b}{n}}
\renewcommand\Affilfont{\fontsize{10}{12}\usefont{OT1}{phv}{m}{n}}

%% ---- Section headings (sans-serif, Nature-like) ----
\RequirePackage[explicit]{titlesec}

\titleformat{\section}
  {\large\sffamily\bfseries}
  {\thesection}
  {0.5em}
  {#1}
  []
\titleformat{name=\section,numberless}
  {\large\sffamily\bfseries}
  {}
  {0em}
  {#1}
  []
\titleformat{\subsection}
  {\sffamily\bfseries}
  {\thesubsection}
  {0.5em}
  {#1}
  []
\titleformat{\subsubsection}
  {\sffamily\small\bfseries\itshape}
  {\thesubsubsection}
  {0.5em}
  {#1}
  []
\titleformat{\paragraph}[runin]
  {\sffamily\small\bfseries}
  {}
  {0em}
  {#1}

\titlespacing*{\section}{0pt}{3ex plus 4pt minus 3pt}{5pt}
\titlespacing*{\subsection}{0pt}{2.5ex plus 3pt minus 2pt}{0pt}
\titlespacing*{\subsubsection}{0pt}{2ex plus 2.5pt minus 1.5pt}{0pt}
\titlespacing*{\paragraph}{0pt}{1.5ex plus 2pt minus 1pt}{10pt}

%% ---- Captions ----
\RequirePackage[
    labelfont={bf,sf},
    labelsep=period,
    justification=raggedright,
    font=small,
]{caption}

%% ---- Headers and footers ----
\RequirePackage{fancyhdr}
\RequirePackage{lastpage}
\pagestyle{fancy}
\fancyhf{}
\rfoot{\small\sffamily\bfseries\thepage/\pageref{LastPage}}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

%% ---- Hyperlinks ----
\RequirePackage[colorlinks=true, allcolors=blue]{hyperref}

%% ---- Bibliography ----
% \RequirePackage{natbib}  % Replaced by biblatex (biber backend) for UTF-8 support and Lastname, F. convention.
\RequirePackage[
    style = authoryear,
    natbib = true,          % \cite, \citep, \citet keep working
    backend = biber,
    giveninits = true,      % Lastname, F.
    maxcitenames = 2,
    maxbibnames = 99,
    uniquelist = false,
    uniquename = false,
    dashed = false,
]{biblatex}

%%% Make the entire in-text citation (author + year) one clickable hyperlink %%%
\DeclareCiteCommand{\cite}
  {\usebibmacro{prenote}}
  {\usebibmacro{citeindex}%
   \printtext[bibhyperref]{\usebibmacro{cite}}}
  {\multicitedelim}
  {\usebibmacro{postnote}}

\DeclareCiteCommand{\parencite}[\mkbibparens]
  {\usebibmacro{prenote}}
  {\usebibmacro{citeindex}%
   \printtext[bibhyperref]{\usebibmacro{cite}}}
  {\multicitedelim}
  {\usebibmacro{postnote}}

\DeclareCiteCommand{\textcite}
  {\boolfalse{cbx:parens}}
  {\usebibmacro{citeindex}%
   \printtext[bibhyperref]{\usebibmacro{textcite}}}
  {\ifbool{cbx:parens}{\bibcloseparen\global\boolfalse{cbx:parens}}{}%
   \multicitedelim}
  {\usebibmacro{textcite:postnote}}

%% ---- Reference formatting ---- %%
% Target: Authors (Year) Title. Journal Vol(Number):Pages. doi:DOI

% Allow DOIs and URLs to break across lines
\setcounter{biburlnumpenalty}{100}
\setcounter{biburlucpenalty}{100}
\setcounter{biburllcpenalty}{100}

% DOI as clickable hyperlink with "doi:" prefix
\DeclareFieldFormat{doi}{%
  doi\addcolon\space
  \ifhyperref
    {\href{https://doi.org/#1}{\nolinkurl{#1}}}
    {\nolinkurl{#1}}%
}

% Suppress ISSN and "visited on" date everywhere; hide URL when DOI is present
\AtEveryBibitem{\clearfield{issn}}
\AtEveryBibitem{%
  \clearfield{urlyear}%
  \clearfield{urlmonth}%
  \clearfield{urlday}%
}
\AtEveryBibitem{%
  \iffieldundef{doi}
    {}
    {\clearfield{url}}%
}

% Year only — no month or day for papers
\AtEveryBibitem{%
  \clearfield{month}%
  \clearfield{day}%
  \clearfield{endmonth}%
  \clearfield{endday}%
}

% Suppress publisher/location for articles and preprints (keep for book/inbook)
\AtEveryBibitem{%
  \ifentrytype{book}
    {}
    {\ifentrytype{inbook}
      {}
      {\clearlist{publisher}\clearlist{location}}}%
}

% Omit "In:" before journal names (keep for book chapters)
\renewbibmacro{in:}{%
  \ifentrytype{article}{}{\printtext{\bibstring{in}\intitlepunct}}%
}

% Volume(Number):Pages format
\renewbibmacro*{volume+number+eid}{%
  \printfield{volume}%
  \iffieldundef{number}
    {}
    {\mkbibparens{\printfield{number}}}%
  \setunit*{\addcolon}%
  \printfield{eid}%
}
\DeclareFieldFormat[article]{pages}{#1}
%% ---- End reference formatting ---- %%

%% ---- Abstract formatting ----
% Shaded box with sans-serif ABSTRACT header, matching Nature style
\RequirePackage{framed}
\newenvironment{manuscript-abstract}{%
  \noindent{\large\sffamily\bfseries ABSTRACT}\par\vskip6pt
  \small\sffamily
}{%
  \par\vskip18pt
}

%% ---- Title formatting ----
\renewcommand{\@maketitle}{%
  \vskip-12pt%
  {\raggedright\sffamily\bfseries\fontsize{20}{25}\selectfont \@title\par}%
  \vskip10pt%
  {\raggedright \@author\par}%
  \vskip8pt%
  {\raggedright \@date\par}%
  \vskip18pt%
}

%% ---- Compact bibliography ----
\let\oldbibliography\thebibliography
\renewcommand{\thebibliography}[1]{%
  \oldbibliography{#1}%
  \setlength\itemsep{0pt}%
}

%% ---- Enumeration style ----
\RequirePackage{enumitem}

\endinput
